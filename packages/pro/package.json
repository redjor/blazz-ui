			"types": "./dist/index.d.ts"
		},
		"./components/blocks/*": {
			"import": "./src/components/blocks/*.tsx",
			"types": "./src/components/blocks/*.tsx"
		},
		"./components/blocks/page-header": {
			"import": "./src/components/blocks/page-header.tsx",
			"types": "./src/components/blocks/page-header.tsx"
		},
		"./components/blocks/stats-grid": {
