{
  "name": "react-dirty-guard",
  "version": "0.1.0",
  "description": "Protect users from losing unsaved form changes. Headless hook + optional styled bar.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bar": {
      "types": "./dist/dirty-guard-bar.d.ts",
      "import": "./dist/dirty-guard-bar.js",
      "require": "./dist/dirty-guard-bar.cjs"
    },
    "./adapters/react-hook-form": {
      "types": "./dist/adapters/react-hook-form.d.ts",
      "import": "./dist/adapters/react-hook-form.js",
      "require": "./dist/adapters/react-hook-form.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-hook-form": ">=7.0.0",
    "tailwindcss": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "react",
    "form",
    "unsaved-changes",
    "dirty",
    "guard",
    "beforeunload",
    "navigation",
    "hook"
  ]
}
