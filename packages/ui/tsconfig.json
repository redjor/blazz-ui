{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"incremental": false
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist"]
}
