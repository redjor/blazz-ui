{
	"$schema": "https://v2-8-11.turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", ".output/**", "dist/**", "out/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"type-check": {
			"dependsOn": ["^build"]
		}
	}
}
