{
	"name": "blazz",
	"private": true,
	"scripts": {
		"dev": "turbo dev",
		"dev:docs": "turbo dev --filter=docs",
		"dev:ops": "turbo dev --filter=ops",
		"dev:worker": "cd apps/ops && pnpm worker:dev",
		"dev:sandbox": "turbo dev --filter=sandbox",
		"build": "turbo build",
		"lint": "turbo lint",
		"test": "turbo test",
		"type-check": "turbo type-check",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "turbo build --filter='!ops' && changeset publish",
		"release:dry": "turbo build --filter='!ops' && changeset publish --dry-run",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@changesets/cli": "^2.30.0",
		"@chromatic-com/storybook": "^4.1.3",
		"@storybook/addon-a11y": "^10.2.17",
		"@storybook/addon-docs": "^10.2.17",
		"@storybook/addon-onboarding": "^10.2.17",
		"@storybook/addon-vitest": "^10.2.17",
		"@storybook/nextjs-vite": "^10.2.17",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@vitejs/plugin-react": "^5.1.4",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"eslint": "^9",
		"eslint-config-next": "16.1.1",
		"eslint-plugin-storybook": "^10.2.17",
		"husky": "^9.1.7",
		"jsdom": "^28.0.0",
		"lint-staged": "^16.4.0",
		"playwright": "^1.58.2",
		"storybook": "^10.2.17",
		"turbo": "^2.8.16",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"biome check --write --no-errors-on-unmatched"
		],
		"*.{json,css,md}": [
			"biome format --write --no-errors-on-unmatched"
		]
	},
	"packageManager": "pnpm@9.9.0",
	"pnpm": {
		"overrides": {
			"react": "19.2.4",
			"react-dom": "19.2.4"
		}
	}
}
