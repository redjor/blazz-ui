# Blazz UI App - Environment Variables Template
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# =============================================================================
# APPLICATION
# =============================================================================

# Application name (displayed in UI, meta tags, etc.)
NEXT_PUBLIC_APP_NAME="Blazz UI App"

# Application URL (for redirects, emails, SEO)
NEXT_PUBLIC_APP_URL="http://localhost:3100"

# Application version (optional, for display/tracking)
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Environment (development, staging, production)
NEXT_PUBLIC_ENVIRONMENT="development"

# =============================================================================
# API & BACKEND
# =============================================================================

# API base URL (if using external API)
NEXT_PUBLIC_API_URL=""

# API secret key (server-side only, not exposed to client)
API_SECRET_KEY=""

# API timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT="30000"

# =============================================================================
# DATABASE (if applicable)
# =============================================================================

# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=""

# Database connection pool size
DATABASE_POOL_SIZE="10"

# =============================================================================
# AUTHENTICATION
# =============================================================================

# NextAuth.js configuration (if using NextAuth)
NEXTAUTH_URL="http://localhost:3100"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32

# OAuth Providers (uncomment and fill if needed)

# Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Auth0
# AUTH0_DOMAIN=""
# AUTH0_CLIENT_ID=""
# AUTH0_CLIENT_SECRET=""

# Clerk
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# CLERK_SECRET_KEY=""

# =============================================================================
# FEATURES FLAGS
# =============================================================================

# Enable/disable features (true/false)

# Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS="false"

# Internationalization (i18n)
NEXT_PUBLIC_ENABLE_I18N="false"

# Command Palette (⌘K)
NEXT_PUBLIC_ENABLE_COMMAND_PALETTE="true"

# Dark mode toggle
NEXT_PUBLIC_ENABLE_DARK_MODE="true"

# Maintenance mode
NEXT_PUBLIC_MAINTENANCE_MODE="false"

# Debug mode (shows extra logging, dev tools)
NEXT_PUBLIC_DEBUG="false"

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS="false"

# Sentry (error tracking)
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# Posthog (product analytics)
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST=""

# Mixpanel
# NEXT_PUBLIC_MIXPANEL_TOKEN=""

# =============================================================================
# EMAIL
# =============================================================================

# SMTP Configuration
# EMAIL_SERVER_HOST=""
# EMAIL_SERVER_PORT="587"
# EMAIL_SERVER_USER=""
# EMAIL_SERVER_PASSWORD=""
# EMAIL_FROM=""

# SendGrid
# SENDGRID_API_KEY=""

# Resend
# RESEND_API_KEY=""

# Mailgun
# MAILGUN_API_KEY=""
# MAILGUN_DOMAIN=""

# =============================================================================
# STORAGE & UPLOADS
# =============================================================================

# AWS S3
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# AWS_S3_BUCKET=""

# Cloudinary
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# Uploadthing
# UPLOADTHING_SECRET=""
# UPLOADTHING_APP_ID=""

# =============================================================================
# PAYMENT & BILLING (if applicable)
# =============================================================================

# Stripe
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# PayPal
# PAYPAL_CLIENT_ID=""
# PAYPAL_CLIENT_SECRET=""

# =============================================================================
# THIRD-PARTY SERVICES
# =============================================================================

# OpenAI
# OPENAI_API_KEY=""

# Maps
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Pusher (real-time)
# NEXT_PUBLIC_PUSHER_KEY=""
# PUSHER_SECRET=""
# PUSHER_APP_ID=""
# PUSHER_CLUSTER=""

# Algolia (search)
# NEXT_PUBLIC_ALGOLIA_APP_ID=""
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""
# ALGOLIA_ADMIN_KEY=""

# =============================================================================
# SECURITY
# =============================================================================

# CSRF Token Secret
CSRF_SECRET=""  # Generate with: openssl rand -base64 32

# Rate limiting
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes

# Allowed origins (for CORS)
ALLOWED_ORIGINS="http://localhost:3100,http://localhost:3000"

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Disable telemetry
NEXT_TELEMETRY_DISABLED="1"

# Turbopack (Next.js 14+)
# TURBOPACK="1"

# Show React dev overlay errors
# NEXT_PUBLIC_SHOW_ERROR_OVERLAY="true"

# =============================================================================
# CUSTOM SETTINGS
# =============================================================================

# Add your custom environment variables below
# Example:
# MY_CUSTOM_VAR=""
