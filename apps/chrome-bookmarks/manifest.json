{
	"manifest_version": 3,
	"name": "Blazz Bookmarks",
	"version": "1.0.0",
	"description": "Sauvegardez des pages directement dans Blazz Ops depuis Chrome",
	"permissions": ["activeTab", "contextMenus", "storage"],
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"32": "icons/icon32.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"icons": {
		"16": "icons/icon16.png",
		"32": "icons/icon32.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"background": {
		"service_worker": "background.js"
	},
	"options_ui": {
		"page": "options.html",
		"open_in_tab": false
	}
}
