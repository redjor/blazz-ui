# Convex
CONVEX_DEPLOYMENT=             # Convex deployment slug (e.g. "your-app-123")
NEXT_PUBLIC_CONVEX_URL=        # Convex deployment URL
NEXT_PUBLIC_CONVEX_SITE_URL=   # Convex HTTP actions URL

# Blazz
NEXT_PUBLIC_BLAZZ_LICENSE_KEY= # @blazz/pro license key

# OpenAI
OPENAI_API_KEY=                # OpenAI API key (for AI features)

# Vercel
VERCEL_TOKEN=                  # Vercel API token
VERCEL_PROJECT_ID=             # Vercel project ID

# Notification webhooks
GITHUB_WEBHOOK_SECRET=         # Secret for GitHub webhook signature verification
VERCEL_WEBHOOK_SECRET=         # Secret for Vercel webhook signature verification
CONVEX_WEBHOOK_SECRET=         # Secret for custom Convex webhook
OPS_USER_ID=                   # Your Convex user ID (for webhook → notification mapping)

# Chrome Extension
EXTENSION_SECRET=              # Secret shared with the Blazz Bookmarks Chrome extension
