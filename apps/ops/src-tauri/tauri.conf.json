{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Blazz Ops",
	"version": "0.1.0",
	"identifier": "dev.blazz.ops",
	"build": {
		"beforeBuildCommand": "bash scripts/tauri-build.sh",
		"beforeDevCommand": "pnpm dev:ops",
		"frontendDist": "./loading",
		"devUrl": "http://localhost:3120"
	},
	"app": {
		"security": {
			"csp": null
		},
		"windows": [
			{
				"title": "Blazz Ops",
				"width": 1200,
				"height": 800,
				"minWidth": 900,
				"minHeight": 600
			}
		]
	},
	"bundle": {
		"active": true,
		"targets": ["dmg", "app"],
		"resources": {
			"../server-bundle/": "server/"
		},
		"icon": ["icons/icon.icns", "icons/icon.ico", "icons/32x32.png", "icons/128x128.png"]
	}
}
