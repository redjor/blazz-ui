generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  avatar    String?
  role      UserRole @default(SALES)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assignedDeals Deal[]     @relation("DealAssignee")
  createdDeals  Deal[]     @relation("DealCreator")
  activities    Activity[]
  quotes        Quote[]

  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  SALES
}

// ─── Companies ───────────────────────────────────────────────────────────────

model Company {
  id        String        @id @default(cuid())
  name      String
  domain    String?
  industry  String?
  size      CompanySize?
  revenue   Float?
  phone     String?
  email     String?
  address   String?
  city      String?
  zipCode   String?
  country   String?       @default("France")
  website   String?
  notes     String?
  status    CompanyStatus @default(PROSPECT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  contacts   Contact[]
  deals      Deal[]
  activities Activity[]

  @@map("companies")
}

enum CompanyStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  CHURNED
}

enum CompanySize {
  SOLO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

// ─── Contacts ────────────────────────────────────────────────────────────────

model Contact {
  id        String        @id @default(cuid())
  firstName String
  lastName  String
  email     String        @unique
  phone     String?
  jobTitle  String?
  isPrimary Boolean       @default(false)
  status    ContactStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  companyId  String
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deals      Deal[]     @relation("DealContact")
  activities Activity[]

  @@map("contacts")
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  BOUNCED
}

// ─── Deals ───────────────────────────────────────────────────────────────────

model Deal {
  id                String    @id @default(cuid())
  title             String
  amount            Float     @default(0)
  stage             DealStage @default(QUALIFICATION)
  probability       Int       @default(10)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  notes             String?
  source            DealSource @default(OUTBOUND)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId    String?
  contact      Contact?   @relation("DealContact", fields: [contactId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?      @relation("DealAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?      @relation("DealCreator", fields: [createdById], references: [id], onDelete: SetNull)
  quotes       Quote[]
  activities   Activity[]

  @@map("deals")
}

enum DealStage {
  QUALIFICATION
  DISCOVERY
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum DealSource {
  INBOUND
  OUTBOUND
  REFERRAL
  PARTNER
  EVENT
  WEBSITE
}

// ─── Products ────────────────────────────────────────────────────────────────

model Product {
  id          String        @id @default(cuid())
  name        String
  description String?
  sku         String        @unique
  unitPrice   Float
  currency    String        @default("EUR")
  category    String?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  quoteLines QuoteLine[]

  @@map("products")
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

// ─── Quotes ──────────────────────────────────────────────────────────────────

model Quote {
  id          String      @id @default(cuid())
  reference   String      @unique
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime?
  discount    Float       @default(0)
  taxRate     Float       @default(20)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  dealId      String
  deal        Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lines       QuoteLine[]

  @@map("quotes")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model QuoteLine {
  id          String @id @default(cuid())
  quantity    Int    @default(1)
  unitPrice   Float
  discount    Float  @default(0)
  description String?

  // Relations
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("quote_lines")
}

// ─── Activities ──────────────────────────────────────────────────────────────

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String?
  date        DateTime     @default(now())
  createdAt   DateTime     @default(now())

  // Relations — polymorphique via optional FKs
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("activities")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  STATUS_CHANGE
  DEAL_CREATED
  DEAL_WON
  DEAL_LOST
  QUOTE_SENT
}
